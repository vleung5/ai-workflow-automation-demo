# Environment
ENV=dev
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Processing
MAX_WORKERS=4
QUEUE_MAX_SIZE=100
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads

# S3
S3_BUCKET=
S3_PREFIX=incoming/
S3_POLLING_INTERVAL=30

# AWS
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ENABLED=false
SECRET_NAME=ai-workflow-automation/dev/secrets

# Datadog
DATADOG_ENABLED=false
DATADOG_SITE=datadoghq.com
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_AGENT_HOST=localhost
DATADOG_AGENT_PORT=8126

# Datadog Service
DD_SERVICE=ai-workflow-automation
DD_VERSION=2.0.0
DD_ENV=dev

# Datadog Tracing
DD_TRACE_ENABLED=true
DD_APM_ENABLED=true
DD_SAMPLE_RATE=0.1
DD_TRACE_DEBUG=false

# Datadog Metrics
DD_METRICS_ENABLED=true
DD_METRICS_NAMESPACE=ai_workflow

# Datadog Profiler
DD_PROFILER_ENABLED=false
DD_PROFILER_SERVICE=ai-workflow-automation

# Datadog Logging
DD_JSON_LOGGING=true
DD_LOG_CORRELATION=true
DD_TAGS=team:platform,cost_center:engineering
